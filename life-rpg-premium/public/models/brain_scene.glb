<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Realistic 3D Brain Atlas — Background</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            margin: 0; 
            overflow: hidden; 
            background: #0a0a1a; 
            font-family: 'Inter', 'Segoe UI', sans-serif; 
        }
        
        #brain-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }
        
        /* Overlay UI for your website content */
        #content-overlay {
            position: relative;
            z-index: 10;
            pointer-events: none;
            min-height: 100vh;
        }
        
        #content-overlay > * {
            pointer-events: auto;
        }
        
        /* Brain Atlas UI Controls */
        #atlas-controls {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            background: rgba(10, 10, 30, 0.85);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 16px;
            width: 260px;
            color: #e0e0ff;
            font-size: 13px;
            transition: opacity 0.3s;
        }
        
        #atlas-controls.hidden { opacity: 0; pointer-events: none; }
        
        .control-group {
            margin-bottom: 14px;
        }
        
        .control-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #8899cc;
            margin-bottom: 6px;
            display: block;
        }
        
        .control-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #ccd6f6;
            padding: 6px 12px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 12px;
            margin: 2px;
            transition: all 0.2s;
            font-family: inherit;
        }
        
        .control-btn:hover {
            background: rgba(0, 212, 170, 0.2);
            border-color: rgba(0, 212, 170, 0.4);
        }
        
        .control-btn.active {
            background: rgba(0, 212, 170, 0.3);
            border-color: #00d4aa;
            color: #00d4aa;
        }
        
        input[type="range"] {
            width: 100%;
            height: 4px;
            border-radius: 2px;
            background: rgba(255,255,255,0.1);
            outline: none;
            -webkit-appearance: none;
        }
        
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #00d4aa;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0, 212, 170, 0.5);
        }
        
        /* Structure Info Panel */
        #structure-panel {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 100;
            background: rgba(10, 10, 30, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            width: 300px;
            color: #e0e0ff;
            transform: translateX(-350px);
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            max-height: 80vh;
            overflow-y: auto;
        }
        
        #structure-panel.visible {
            transform: translateX(0);
        }
        
        #structure-panel h2 {
            font-size: 20px;
            color: #00d4aa;
            margin-bottom: 8px;
            font-weight: 700;
        }
        
        #structure-panel .subtitle {
            font-size: 12px;
            color: #8899cc;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }
        
        #structure-panel p {
            font-size: 13px;
            line-height: 1.6;
            color: #b0b8d8;
        }
        
        /* Slice Plane Indicator */
        #slice-indicator {
            position: fixed;
            bottom: 80px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
            background: rgba(10, 10, 30, 0.8);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 30px;
            padding: 10px 24px;
            color: #8899cc;
            font-size: 12px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        #slice-indicator.visible { opacity: 1; }
        
        /* Loading Screen */
        #loading {
            position: fixed;
            inset: 0;
            background: #0a0a1a;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #00d4aa;
            transition: opacity 0.5s;
        }
        
        #loading.hidden { opacity: 0; pointer-events: none; }
        
        .loading-brain {
            width: 80px;
            height: 80px;
            border: 3px solid rgba(0, 212, 170, 0.2);
            border-top-color: #00d4aa;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        /* Toggle UI button */
        #toggle-ui {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 100;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(10, 10, 30, 0.8);
            border: 1px solid rgba(255,255,255,0.15);
            color: #ccd6f6;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        
        #toggle-ui:hover {
            background: rgba(0, 212, 170, 0.2);
            border-color: #00d4aa;
        }
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading">
        <div class="loading-brain"></div>
        <div style="font-size: 14px; letter-spacing: 2px;">INITIALIZING BRAIN ATLAS...</div>
    </div>

    <!-- 3D Canvas -->
    <canvas id="brain-canvas"></canvas>

    <!-- Structure Info Panel (appears on click) -->
    <div id="structure-panel">
        <div class="subtitle" id="panel-category">Cerebral Cortex</div>
        <h2 id="panel-title">Frontal Lobe</h2>
        <p id="panel-description">Responsible for executive functions, decision making, personality expression, and moderating social behavior. Contains the motor cortex and prefrontal cortex.</p>
    </div>

    <!-- Atlas Controls -->
    <div id="atlas-controls">
        <div class="control-group">
            <span class="control-label">View Mode</span>
            <button class="control-btn active" onclick="setViewMode('surface')">Surface</button>
            <button class="control-btn" onclick="setViewMode('transparent')">Transparent</button>
            <button class="control-btn" onclick="setViewMode('xray')">X-Ray</button>
        </div>
        
        <div class="control-group">
            <span class="control-label">Cortex Opacity</span>
            <input type="range" id="opacity-slider" min="0" max="100" value="85" oninput="updateOpacity(this.value)">
        </div>
        
        <div class="control-group">
            <span class="control-label">Slice Plane</span>
            <button class="control-btn" onclick="setSlicePlane('sagittal')">Sagittal</button>
            <button class="control-btn" onclick="setSlicePlane('coronal')">Coronal</button>
            <button class="control-btn" onclick="setSlicePlane('horizontal')">Horizontal</button>
            <button class="control-btn active" onclick="setSlicePlane('none')">None</button>
        </div>
        
        <div class="control-group">
            <span class="control-label">Auto Rotate</span>
            <button class="control-btn active" onclick="toggleRotation(this)" id="rotate-btn">On</button>
        </div>
        
        <div class="control-group">
            <span class="control-label">Highlight</span>
            <button class="control-btn" onclick="highlightStructure('all')">All</button>
            <button class="control-btn" onclick="highlightStructure('cortex')">Cortex</button>
            <button class="control-btn" onclick="highlightStructure('subcortical')">Subcortical</button>
        </div>
    </div>

    <!-- Slice Indicator -->
    <div id="slice-indicator">Slice Plane Active</div>

    <!-- Toggle UI -->
    <button id="toggle-ui" onclick="toggleUI()" title="Toggle Controls">⚙️</button>

    <!-- Your Website Content Goes Here -->
    <div id="content-overlay">
        <!-- Example: Your Life RPG app content would go here -->
        <!-- The brain renders behind everything -->
    </div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // ===== CONFIGURATION =====
        const CONFIG = {
            bgColor: 0x0a0a1a,
            brainColor: 0xc4887a,
            brainColorDark: 0x8b5a5a,
            highlightColor: 0x00d4aa,
            subcorticalColor: 0xd4a088,
            ventricleColor: 0x4488cc,
            particleCount: 800,
            autoRotateSpeed: 0.3
        };

        // ===== STATE =====
        let scene, camera, renderer, controls;
        let brainGroup, slicePlane;
        let currentSlice = 'none';
        let isRotating = true;
        let cortexOpacity = 0.85;
        let highlightedMeshes = [];
        
        // Brain structure database (anatomically accurate descriptions)
        const BRAIN_STRUCTURES = {
            'frontal': {
                name: 'Frontal Lobe',
                category: 'Cerebral Cortex',
                description: 'The largest lobe, responsible for executive functions, decision making, planning, personality expression, and moderating social behavior. Contains the primary motor cortex and prefrontal cortex.'
            },
            'parietal': {
                name: 'Parietal Lobe',
                category: 'Cerebral Cortex',
                description: 'Processes sensory information regarding the location of parts of the body as well as interpreting visual information and processing language and mathematics.'
            },
            'temporal': {
                name: 'Temporal Lobe',
                category: 'Cerebral Cortex',
                description: 'Contains the primary auditory cortex and is critical for processing auditory information, memory formation (hippocampus), and language comprehension (Wernicke\'s area).'
            },
            'occipital': {
                name: 'Occipital Lobe',
                category: 'Cerebral Cortex',
                description: 'The visual processing center containing the primary visual cortex. Interprets visual stimuli including color, form, and motion.'
            },
            'cerebellum': {
                name: 'Cerebellum',
                category: 'Hindbrain',
                description: 'Coordinates voluntary movements, balance, posture, and motor learning. Contains over 50% of the brain\'s neurons despite being only 10% of its volume.'
            },
            'brainstem': {
                name: 'Brainstem',
                category: 'Hindbrain',
                description: 'Connects the cerebrum and cerebellum to the spinal cord. Controls autonomic functions including breathing, heart rate, and blood pressure.'
            },
            'thalamus': {
                name: 'Thalamus',
                category: 'Subcortical',
                description: 'The brain\'s relay station. Processes and transmits sensory and motor signals to the cerebral cortex. Regulates consciousness, sleep, and alertness.'
            },
            'hippocampus': {
                name: 'Hippocampus',
                category: 'Limbic System',
                description: 'Critical for memory formation, organization, and storage. Converts short-term memories to long-term memories and spatial navigation.'
            },
            'amygdala': {
                name: 'Amygdala',
                category: 'Limbic System',
                description: 'Processes emotions, especially fear and threat detection. Plays a key role in emotional learning and memory modulation.'
            },
            'basal_ganglia': {
                name: 'Basal Ganglia',
                category: 'Subcortical',
                description: 'Group of nuclei involved in motor control, procedural learning, habit formation, and emotion. Includes the caudate nucleus and putamen.'
            },
            'ventricles': {
                name: 'Lateral Ventricles',
                category: 'Ventricles',
                description: 'Cavities within the brain filled with cerebrospinal fluid (CSF). Cushions the brain, removes waste, and provides nutrients.'
            },
            'corpus_callosum': {
                name: 'Corpus Callosum',
                category: 'White Matter',
                description: 'The largest white matter structure, connecting the left and right cerebral hemispheres and enabling communication between them.'
            }
        };

        // ===== INITIALIZATION =====
        function init() {
            const canvas = document.getElementById('brain-canvas');
            
            // Scene
            scene = new THREE.Scene();
            scene.background = new THREE.Color(CONFIG.bgColor);
            scene.fog = new THREE.FogExp2(CONFIG.bgColor, 0.02);

            // Camera
            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
            camera.position.set(0, 0, 5);

            // Renderer
            renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.2;

            // Controls
            controls = new OrbitControls(camera, canvas);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.autoRotate = true;
            controls.autoRotateSpeed = CONFIG.autoRotateSpeed;
            controls.minDistance = 2;
            controls.maxDistance = 10;
            controls.enablePan = false;

            // Lights
            setupLights();

            // Create Brain
            createRealisticBrain();

            // Create Particles
            createParticles();

            // Slice Plane
            createSlicePlane();

            // Event Listeners
            window.addEventListener('resize', onResize);
            canvas.addEventListener('click', onBrainClick);
            canvas.addEventListener('mousemove', onBrainHover);

            // Hide loading
            setTimeout(() => {
                document.getElementById('loading').classList.add('hidden');
            }, 1500);

            // Animation Loop
            animate();
        }

        function setupLights() {
            // Ambient
            const ambient = new THREE.AmbientLight(0x404080, 0.4);
            scene.add(ambient);

            // Main directional (simulating surgical light)
            const mainLight = new THREE.DirectionalLight(0xfff0e0, 1.5);
            mainLight.position.set(2, 3, 4);
            mainLight.castShadow = true;
            mainLight.shadow.mapSize.width = 2048;
            mainLight.shadow.mapSize.height = 2048;
            scene.add(mainLight);

            // Fill light (cool blue)
            const fillLight = new THREE.DirectionalLight(0x6080ff, 0.4);
            fillLight.position.set(-3, 1, -2);
            scene.add(fillLight);

            // Rim light (teal accent)
            const rimLight = new THREE.DirectionalLight(0x00d4aa, 0.3);
            rimLight.position.set(0, -2, -3);
            scene.add(rimLight);

            // Subtle point lights for depth
            const pointLight1 = new THREE.PointLight(0xff8866, 0.5, 10);
            pointLight1.position.set(1, 1, 2);
            scene.add(pointLight1);

            const pointLight2 = new THREE.PointLight(0x6688ff, 0.3, 10);
            pointLight2.position.set(-1, -1, 2);
            scene.add(pointLight2);
        }

        // ===== REALISTIC BRAIN GENERATION =====
        function createRealisticBrain() {
            brainGroup = new THREE.Group();

            // Materials
            const cortexMaterial = new THREE.MeshPhysicalMaterial({
                color: CONFIG.brainColor,
                roughness: 0.6,
                metalness: 0.05,
                clearcoat: 0.3,
                clearcoatRoughness: 0.4,
                sheen: 0.2,
                sheenColor: 0xffaaaa,
                side: THREE.DoubleSide
            });

            const subcorticalMaterial = new THREE.MeshPhysicalMaterial({
                color: CONFIG.subcorticalColor,
                roughness: 0.7,
                metalness: 0.0,
                transparent: true,
                opacity: 0.9
            });

            const ventricleMaterial = new THREE.MeshPhysicalMaterial({
                color: CONFIG.ventricleColor,
                roughness: 0.3,
                metalness: 0.1,
                transparent: true,
                opacity: 0.4,
                emissive: 0x224466,
                emissiveIntensity: 0.2
            });

            const whiteMatterMaterial = new THREE.MeshStandardMaterial({
                color: 0xf5f0e8,
                roughness: 0.8
            });

            // 1. CEREBRAL HEMISPHERES (Procedurally generated with gyri/sulci)
            const leftHemisphere = createHemisphere(true, cortexMaterial);
            const rightHemisphere = createHemisphere(false, cortexMaterial);
            brainGroup.add(leftHemisphere);
            brainGroup.add(rightHemisphere);

            // 2. CEREBELLUM
            const cerebellum = createCerebellum(cortexMaterial);
            brainGroup.add(cerebellum);

            // 3. BRAINSTEM
            const brainstem = createBrainstem(cortexMaterial);
            brainGroup.add(brainstem);

            // 4. SUBCORTICAL STRUCTURES (visible through transparent cortex)
            const thalamus = createThalamus(subcorticalMaterial);
            brainGroup.add(thalamus);

            const hippocampus = createHippocampus(subcorticalMaterial);
            brainGroup.add(hippocampus);

            const amygdala = createAmygdala(subcorticalMaterial);
            brainGroup.add(amygdala);

            const basalGanglia = createBasalGanglia(subcorticalMaterial);
            brainGroup.add(basalGanglia);

            // 5. VENTRICLES
            const ventricles = createVentricles(ventricleMaterial);
            brainGroup.add(ventricles);

            // 6. CORPUS CALLOSUM
            const corpusCallosum = createCorpusCallosum(whiteMatterMaterial);
            brainGroup.add(corpusCallosum);

            scene.add(brainGroup);
        }

        function createHemisphere(isLeft, material) {
            const group = new THREE.Group();
            
            // Base ellipsoid for hemisphere
            const geometry = new THREE.SphereGeometry(1, 64, 64);
            const mesh = new THREE.Mesh(geometry, material.clone());
            
            // Deform to create brain-like shape
            const positions = geometry.attributes.position;
            for (let i = 0; i < positions.count; i++) {
                const x = positions.getX(i);
                const y = positions.getY(i);
                const z = positions.getZ(i);
                
                // Flatten bottom, elongate front-back
                const nx = x * 0.75;
                const ny = y * 0.85 - 0.1;
                const nz = z * 1.0;
                
                // Add gyri (ridges) using noise-like deformation
                const noise = Math.sin(nx * 8) * Math.cos(ny * 6) * Math.sin(nz * 7);
                const displacement = 1 + noise * 0.08;
                
                positions.setXYZ(i, nx * displacement, ny * displacement, nz * displacement);
            }
            geometry.computeVertexNormals();
            
            mesh.scale.set(1.1, 1.0, 1.3);
            mesh.position.set(isLeft ? -0.6 : 0.6, 0.2, 0);
            
            // Tag for interaction
            if (isLeft) {
                mesh.userData = { structure: 'frontal', hemisphere: 'left' };
            } else {
                mesh.userData = { structure: 'frontal', hemisphere: 'right' };
            }
            
            group.add(mesh);
            
            // Add lobe subdivisions (invisible hit targets for clicking)
            const lobeNames = ['frontal', 'parietal', 'temporal', 'occipital'];
            const lobePositions = [
                [0, 0.3, 0.6],    // frontal
                [0, 0.6, -0.2],   // parietal
                [0, -0.3, 0.2],   // temporal
                [0, 0.1, -0.8]    // occipital
            ];
            
            lobeNames.forEach((name, idx) => {
                const lobeGeo = new THREE.SphereGeometry(0.4, 16, 16);
                const lobeMesh = new THREE.Mesh(lobeGeo, material.clone());
                lobeMesh.position.set(
                    lobePositions[idx][0] + (isLeft ? -0.6 : 0.6),
                    lobePositions[idx][1] + 0.2,
                    lobePositions[idx][2]
                );
                lobeMesh.scale.set(0.9, 0.7, 0.8);
                lobeMesh.userData = { structure: name, isLobe: true };
                lobeMesh.visible = false; // Invisible hit target
                group.add(lobeMesh);
            });
            
            return group;
        }

        function createCerebellum(material) {
            const geometry = new THREE.SphereGeometry(0.5, 32, 32);
            const mesh = new THREE.Mesh(geometry, material.clone());
            
            // Deform to cerebellar shape
            const positions = geometry.attributes.position;
            for (let i = 0; i < positions.count; i++) {
                const x = positions.getX(i);
                const y = positions.getY(i);
                const z = positions.getZ(i);
                
                // Cerebellum is smaller, more compact, with folia (fine ridges)
                const folia = Math.sin(x * 15) * Math.cos(z * 12) * 0.05;
                const scale = 1 + folia;
                
                positions.setXYZ(i, x * 0.8 * scale, (y - 0.3) * 0.6 * scale, z * 0.5 * scale);
            }
            geometry.computeVertexNormals();
            
            mesh.position.set(0, -0.8, -0.6);
            mesh.userData = { structure: 'cerebellum' };
            
            return mesh;
        }

        function createBrainstem(material) {
            const geometry = new THREE.CylinderGeometry(0.15, 0.2, 0.8, 16);
            const mesh = new THREE.Mesh(geometry, material.clone());
            mesh.position.set(0, -0.6, -0.3);
            mesh.rotation.x = 0.3;
            mesh.userData = { structure: 'brainstem' };
            return mesh;
        }

        function createThalamus(material) {
            const geometry = new THREE.SphereGeometry(0.2, 16, 16);
            const mesh = new THREE.Mesh(geometry, material.clone());
            mesh.scale.set(1, 0.7, 0.8);
            mesh.position.set(0, 0, -0.1);
            mesh.userData = { structure: 'thalamus' };
            return mesh;
        }

        function createHippocampus(material) {
            const group = new THREE.Group();
            const geometry = new THREE.CapsuleGeometry(0.08, 0.3, 8, 16);
            
            const left = new THREE.Mesh(geometry, material.clone());
            left.position.set(-0.35, -0.1, 0.1);
            left.rotation.z = 0.5;
            left.userData = { structure: 'hippocampus' };
            
            const right = new THREE.Mesh(geometry, material.clone());
            right.position.set(0.35, -0.1, 0.1);
            right.rotation.z = -0.5;
            right.userData = { structure: 'hippocampus' };
            
            group.add(left, right);
            return group;
        }

        function createAmygdala(material) {
            const geometry = new THREE.SphereGeometry(0.1, 12, 12);
            const mesh = new THREE.Mesh(geometry, material.clone());
            mesh.position.set(0, -0.15, 0.35);
            mesh.userData = { structure: 'amygdala' };
            return mesh;
        }

        function createBasalGanglia(material) {
            const group = new THREE.Group();
            const geometry = new THREE.SphereGeometry(0.15, 16, 16);
            
            const positions = [
                [-0.4, 0.1, 0], [0.4, 0.1, 0],  // caudate
                [-0.5, -0.1, 0.1], [0.5, -0.1, 0.1]  // putamen
            ];
            
            positions.forEach(pos => {
                const mesh = new THREE.Mesh(geometry, material.clone());
                mesh.position.set(...pos);
                mesh.scale.set(1, 0.7, 0.9);
                mesh.userData = { structure: 'basal_ganglia' };
                group.add(mesh);
            });
            
            return group;
        }

        function createVentricles(material) {
            const group = new THREE.Group();
            
            // Lateral ventricles (C-shaped)
            const ventricleGeo = new THREE.TorusGeometry(0.25, 0.06, 12, 24, Math.PI * 1.5);
            
            const left = new THREE.Mesh(ventricleGeo, material.clone());
            left.position.set(-0.3, 0.3, -0.1);
            left.rotation.set(0.3, 0, 0.5);
            
            const right = new THREE.Mesh(ventricleGeo, material.clone());
            right.position.set(0.3, 0.3, -0.1);
            right.rotation.set(0.3, 0, -0.5);
            
            group.add(left, right);
            return group;
        }

        function createCorpusCallosum(material) {
            const geometry = new THREE.CylinderGeometry(0.08, 0.12, 0.6, 12);
            const mesh = new THREE.Mesh(geometry, material.clone());
            mesh.position.set(0, 0.4, -0.2);
            mesh.rotation.z = Math.PI / 2;
            mesh.rotation.y = 0.2;
            mesh.userData = { structure: 'corpus_callosum' };
            return mesh;
        }

        // ===== SLICE PLANES =====
        function createSlicePlane() {
            const geometry = new THREE.PlaneGeometry(4, 4);
            const material = new THREE.MeshBasicMaterial({
                color: 0x00d4aa,
                transparent: true,
                opacity: 0.15,
                side: THREE.DoubleSide,
                depthWrite: false
            });
            slicePlane = new THREE.Mesh(geometry, material);
            slicePlane.visible = false;
            scene.add(slicePlane);
        }

        function setSlicePlane(type) {
            currentSlice = type;
            const indicator = document.getElementById('slice-indicator');
            
            if (type === 'none') {
                slicePlane.visible = false;
                indicator.classList.remove('visible');
                
                // Reset all materials
                brainGroup.traverse(child => {
                    if (child.isMesh && child.material) {
                        child.material.clippingPlanes = [];
                    }
                });
                renderer.localClippingEnabled = false;
                return;
            }
            
            slicePlane.visible = true;
            indicator.classList.add('visible');
            indicator.textContent = `${type.charAt(0).toUpperCase() + type.slice(1)} Slice`;
            
            renderer.localClippingEnabled = true;
            
            const planes = [];
            if (type === 'sagittal') {
                slicePlane.rotation.set(0, Math.PI / 2, 0);
                slicePlane.position.set(0, 0, 0);
                planes.push(new THREE.Plane(new THREE.Vector3(1, 0, 0), 0));
            } else if (type === 'coronal') {
                slicePlane.rotation.set(0, 0, 0);
                slicePlane.position.set(0, 0, 0);
                planes.push(new THREE.Plane(new THREE.Vector3(0, 0, 1), 0));
            } else if (type === 'horizontal') {
                slicePlane.rotation.set(Math.PI / 2, 0, 0);
                slicePlane.position.set(0, 0, 0);
                planes.push(new THREE.Plane(new THREE.Vector3(0, 1, 0), 0));
            }
            
            brainGroup.traverse(child => {
                if (child.isMesh && child.material) {
                    child.material.clippingPlanes = planes;
                }
            });
        }

        // ===== PARTICLES =====
        function createParticles() {
            const geometry = new THREE.BufferGeometry();
            const positions = new Float32Array(CONFIG.particleCount * 3);
            const colors = new Float32Array(CONFIG.particleCount * 3);
            
            for (let i = 0; i < CONFIG.particleCount; i++) {
                positions[i * 3] = (Math.random() - 0.5) * 20;
                positions[i * 3 + 1] = (Math.random() - 0.5) * 20;
                positions[i * 3 + 2] = (Math.random() - 0.5) * 20;
                
                const color = new THREE.Color();
                color.setHSL(0.5 + Math.random() * 0.3, 0.7, 0.5);
                colors[i * 3] = color.r;
                colors[i * 3 + 1] = color.g;
                colors[i * 3 + 2] = color.b;
            }
            
            geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
            
            const material = new THREE.PointsMaterial({
                size: 0.03,
                vertexColors: true,
                transparent: true,
                opacity: 0.6,
                blending: THREE.AdditiveBlending
            });
            
            const particles = new THREE.Points(geometry, material);
            scene.add(particles);
            
            // Animate particles
            const animateParticles = () => {
                particles.rotation.y += 0.0002;
                requestAnimationFrame(animateParticles);
            };
            animateParticles();
        }

        // ===== INTERACTION =====
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();
        let hoveredMesh = null;

        function onBrainClick(event) {
            updateMouse(event);
            raycaster.setFromCamera(mouse, camera);
            
            const intersects = raycaster.intersectObjects(brainGroup.children, true);
            if (intersects.length > 0) {
                const mesh = intersects[0].object;
                const structureKey = mesh.userData.structure;
                
                if (structureKey && BRAIN_STRUCTURES[structureKey]) {
                    showStructureInfo(structureKey);
                    pulseMesh(mesh);
                }
            }
        }

        function onBrainHover(event) {
            updateMouse(event);
            raycaster.setFromCamera(mouse, camera);
            
            const intersects = raycaster.intersectObjects(brainGroup.children, true);
            
            if (hoveredMesh) {
                hoveredMesh.material.emissive = new THREE.Color(0x000000);
                hoveredMesh.material.emissiveIntensity = 0;
                hoveredMesh = null;
                document.body.style.cursor = 'default';
            }
            
            if (intersects.length > 0) {
                const mesh = intersects[0].object;
                if (mesh.userData.structure) {
                    mesh.material.emissive = new THREE.Color(CONFIG.highlightColor);
                    mesh.material.emissiveIntensity = 0.3;
                    hoveredMesh = mesh;
                    document.body.style.cursor = 'pointer';
                }
            }
        }

        function updateMouse(event) {
            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
        }

        function pulseMesh(mesh) {
            const originalScale = mesh.scale.clone();
            const startTime = Date.now();
            
            function animatePulse() {
                const elapsed = Date.now() - startTime;
                const t = Math.min(elapsed / 400, 1);
                const scale = 1 + Math.sin(t * Math.PI) * 0.1;
                
                mesh.scale.copy(originalScale).multiplyScalar(scale);
                
                if (t < 1) {
                    requestAnimationFrame(animatePulse);
                } else {
                    mesh.scale.copy(originalScale);
                }
            }
            animatePulse();
        }

        function showStructureInfo(key) {
            const data = BRAIN_STRUCTURES[key];
            const panel = document.getElementById('structure-panel');
            
            document.getElementById('panel-category').textContent = data.category;
            document.getElementById('panel-title').textContent = data.name;
            document.getElementById('panel-description').textContent = data.description;
            
            panel.classList.add('visible');
            
            // Auto-hide after 8 seconds
            setTimeout(() => {
                panel.classList.remove('visible');
            }, 8000);
        }

        // ===== UI CONTROLS =====
        window.setViewMode = function(mode) {
            document.querySelectorAll('#atlas-controls .control-btn').forEach(btn => {
                if (btn.textContent.toLowerCase().includes(mode)) {
                    btn.classList.add('active');
                } else if (['surface', 'transparent', 'xray'].some(m => btn.textContent.toLowerCase().includes(m))) {
                    btn.classList.remove('active');
                }
            });
            
            brainGroup.traverse(child => {
                if (child.isMesh && child.material) {
                    switch(mode) {
                        case 'surface':
                            child.material.transparent = child.userData.structure === 'ventricles';
                            child.material.opacity = child.userData.structure === 'ventricles' ? 0.4 : 1;
                            child.material.wireframe = false;
                            break;
                        case 'transparent':
                            child.material.transparent = true;
                            child.material.opacity = child.userData.structure === 'ventricles' ? 0.2 : 0.4;
                            child.material.wireframe = false;
                            break;
                        case 'xray':
                            child.material.transparent = true;
                            child.material.opacity = 0.15;
                            child.material.wireframe = true;
                            break;
                    }
                }
            });
        };

        window.updateOpacity = function(value) {
            cortexOpacity = value / 100;
            brainGroup.traverse(child => {
                if (child.isMesh && child.material && 
                    ['frontal', 'parietal', 'temporal', 'occipital'].includes(child.userData.structure)) {
                    child.material.opacity = cortexOpacity;
                    child.material.transparent = cortexOpacity < 1;
                    child.material.depthWrite = cortexOpacity > 0.5;
                }
            });
        };

        window.setSlicePlane = function(type) {
            // Update button states
            document.querySelectorAll('#atlas-controls .control-btn').forEach(btn => {
                if (['sagittal', 'coronal', 'horizontal', 'none'].some(t => 
                    btn.textContent.toLowerCase() === t)) {
                    btn.classList.toggle('active', btn.textContent.toLowerCase() === type);
                }
            });
            
            if (type === 'none') {
                slicePlane.visible = false;
                document.getElementById('slice-indicator').classList.remove('visible');
                renderer.localClippingEnabled = false;
                brainGroup.traverse(child => {
                    if (child.isMesh && child.material) {
                        child.material.clippingPlanes = [];
                    }
                });
            } else {
                renderer.localClippingEnabled = true;
                slicePlane.visible = true;
                document.getElementById('slice-indicator').classList.add('visible');
                document.getElementById('slice-indicator').textContent = 
                    `${type.charAt(0).toUpperCase() + type.slice(1)} Slice`;
                
                const planes = [];
                if (type === 'sagittal') {
                    slicePlane.rotation.set(0, Math.PI / 2, 0);
                    planes.push(new THREE.Plane(new THREE.Vector3(1, 0, 0), 0));
                } else if (type === 'coronal') {
                    slicePlane.rotation.set(0, 0, 0);
                    planes.push(new THREE.Plane(new THREE.Vector3(0, 0, 1), 0));
                } else if (type === 'horizontal') {
                    slicePlane.rotation.set(Math.PI / 2, 0, 0);
                    planes.push(new THREE.Plane(new THREE.Vector3(0, 1, 0), 0));
                }
                
                brainGroup.traverse(child => {
                    if (child.isMesh && child.material) {
                        child.material.clippingPlanes = planes;
                    }
                });
            }
            currentSlice = type;
        };

        window.toggleRotation = function(btn) {
            isRotating = !isRotating;
            controls.autoRotate = isRotating;
            btn.textContent = isRotating ? 'On' : 'Off';
            btn.classList.toggle('active', isRotating);
        };

        window.highlightStructure = function(type) {
            brainGroup.traverse(child => {
                if (child.isMesh && child.material) {
                    const isCortex = ['frontal', 'parietal', 'temporal', 'occipital'].includes(child.userData.structure);
                    const isSubcortical = ['thalamus', 'hippocampus', 'amygdala', 'basal_ganglia', 'cerebellum', 'brainstem'].includes(child.userData.structure);
                    
                    if (type === 'all') {
                        child.material.emissive = new THREE.Color(0x000000);
                        child.material.emissiveIntensity = 0;
                    } else if (type === 'cortex' && isCortex) {
                        child.material.emissive = new THREE.Color(CONFIG.highlightColor);
                        child.material.emissiveIntensity = 0.4;
                    } else if (type === 'subcortical' && isSubcortical) {
                        child.material.emissive = new THREE.Color(0xff6b9d);
                        child.material.emissiveIntensity = 0.4;
                    } else {
                        child.material.emissive = new THREE.Color(0x000000);
                        child.material.emissiveIntensity = 0;
                    }
                }
            });
        };

        window.toggleUI = function() {
            document.getElementById('atlas-controls').classList.toggle('hidden');
        };

        // ===== ANIMATION =====
        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        // ===== START =====
        init();
    </script>
</body>
</html>